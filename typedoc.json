{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src-vue"],
  "entryPointStrategy": "expand",
  "tsconfig": "tsconfig.json",
  "out": "docs-site/api",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "none",
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/test/**",
    "**/vite-env.d.ts"
  ],
  "skipErrorChecking": true,
  "excludeExternals": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "hideGenerator": true,
  "githubPages": false,
  "validation": {
    "notExported": false
  }
}

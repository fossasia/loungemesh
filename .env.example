# Flowspace — copy to .env.local and adjust for your environment
#
# Quick start (open mode, no access control):
#   cp .env.example .env.local
#   npm run dev            → http://localhost:5173
#
# Local Eventyay testing (eventyay on :8000, flowspace on :5173):
#   VITE_EVENTYAY_API_BASE=http://localhost:8000
#   VITE_EVENTYAY_JWT_ENDPOINT=http://localhost:8000/api/v1/flowspace/token/
#   VITE_ALLOW_IFRAME_FROM=http://localhost:8000
#
# Full Docker stack (Flowspace + local Jitsi):
#   node docker/setup-jitsi-env.mjs
#   docker compose --env-file docker/.env.jitsi up --build
#   → Flowspace on http://localhost:8880
#   → Jitsi web on http://localhost:8001 (or PUBLIC_URL from docker/.env.jitsi)


# --- Jitsi connection ---
# Browser-reachable Jitsi web URL for the Docker stack
# VITE_JITSI_PUBLIC_URL=http://localhost:8001
# VITE_XMPP_DOMAIN=meet.jitsi
# VITE_XMPP_MUC_DOMAIN=muc.meet.jitsi
# Own Jitsi host when XMPP domain equals hostname (single-host)
# VITE_SERVICE_URL=your-jitsi.example.com
# VITE_USE_WEBSOCKET=true
# Room name prefix for secure conference names (default: fls)
# VITE_SESSION_PREFIX=fls


# --- Eventyay integration ---
# Base URL of the running Eventyay instance.
# Set this when Flowspace should load event data and enforce JWT access control.
#
# Production:
# VITE_EVENTYAY_API_BASE=https://eventyay.com
#
# Local development with Eventyay on port 8000:
# VITE_EVENTYAY_API_BASE=http://localhost:8000

# Token exchange endpoint from the eventyay-flowspace plugin.
# When set, /join/:id requires a valid ?token= query param to enter a room.
# Leave unset for open/self-hosted deployments without access control.
#
# Production:
# VITE_EVENTYAY_JWT_ENDPOINT=https://eventyay.com/api/v1/flowspace/token/
#
# Local (eventyay on :8000):
# VITE_EVENTYAY_JWT_ENDPOINT=http://localhost:8000/api/v1/flowspace/token/

# Comma-separated origins allowed to embed Flowspace in an <iframe>.
# Must match the Origin header of the Eventyay instance.
#
# Production:
# VITE_ALLOW_IFRAME_FROM=https://eventyay.com,https://video.eventyay.com
#
# Local:
# VITE_ALLOW_IFRAME_FROM=http://localhost:8000


# --- Docker nginx runtime (not a Vite env var) ---
# Overrides the Content-Security-Policy frame-ancestors header at runtime.
# Set in docker-compose.yml or as a container environment variable.
# NGINX_ALLOW_IFRAME_FROM=https://eventyay.com https://video.eventyay.com


# --- Docs site deploy (CI only) ---
# DOCS_BASE_URL=/
# DOCS_CNAME=docs.flowspace.com

# Flowspace — copy to .env.local and adjust for your environment

# --- Jitsi (public meet.jit.si by default; set these for self-hosted) ---
# Browser-reachable Jitsi web URL when using docker-jitsi-meet
# VITE_JITSI_PUBLIC_URL=http://localhost:8000
# VITE_XMPP_DOMAIN=meet.jitsi
# VITE_XMPP_MUC_DOMAIN=muc.meet.jitsi
# Own Jitsi host when XMPP domain equals hostname
# VITE_SERVICE_URL=your-jitsi.example.com
# VITE_USE_WEBSOCKET=true
# Room name prefix for secure conference names (default: fls)
# VITE_SESSION_PREFIX=fls

# --- Eventyay integration (optional) ---
# VITE_EVENTYAY_API_BASE=https://api.eventyay.com
# JWT token endpoint for secure Jitsi domains
# VITE_EVENTYAY_JWT_ENDPOINT=

# --- Docs site deploy (CI only) ---
# DOCS_BASE_URL=/
# DOCS_CNAME=docs.flowspace.com

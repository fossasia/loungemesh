# Development template — merged into `.env` with: npm run setup
# Re-runs preserve existing values (passwords, custom keys). Use --force to reset non-secrets.

# --- Vite / Flowspace SPA ---
VITE_JITSI_PUBLIC_URL=http://localhost:8001
VITE_XMPP_DOMAIN=meet.jitsi
VITE_XMPP_MUC_DOMAIN=muc.meet.jitsi
VITE_USE_WEBSOCKET=true
VITE_SESSION_PREFIX=fls
# Video/audio diagnostics — filter browser console by "flowspace:media"
# Or enable at runtime: localStorage.setItem('flowspace:media-debug','1'); location.reload()
# VITE_MEDIA_DEBUG=true

# Eventyay (optional — uncomment for local plugin testing)
# VITE_EVENTYAY_API_BASE=http://localhost:8000
# VITE_EVENTYAY_JWT_ENDPOINT=http://localhost:8000/api/v1/flowspace/token/
# VITE_ALLOW_IFRAME_FROM=http://localhost:8000

# --- Docker Compose / Jitsi ---
CONFIG=./docker/jitsi-config
TZ=UTC
FLOWSPACE_PORT=8780
HTTP_PORT=8001
HTTPS_PORT=8444
PUBLIC_URL=http://localhost:8001

ENABLE_AUTH=0
ENABLE_GUESTS=1
ENABLE_XMPP_WEBSOCKET=1
# 0 avoids colibri-ws to a Docker bridge IP (192.168.x.x) when DOCKER_HOST_ADDRESS is wrong.
# Set 1 only after DOCKER_HOST_ADDRESS is your Mac LAN IP and JVB was recreated.
ENABLE_COLIBRI_WEBSOCKET=0
DISABLE_HTTPS=1
ENABLE_HTTP_REDIRECT=0

XMPP_DOMAIN=meet.jitsi
XMPP_SERVER=xmpp.meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_HIDDEN_DOMAIN=hidden.meet.jitsi
XMPP_RECORDER_DOMAIN=recorder.meet.jitsi

PROSODY_TRUSTED_PROXIES=127.0.0.1,::1,172.16.0.0/12
COLIBRI_WEBSOCKET_REGEX=.+

# Populated by: npm run setup
JICOFO_AUTH_PASSWORD=replace-me-run-setup-script
JVB_AUTH_PASSWORD=replace-me-run-setup-script
JIGASI_XMPP_PASSWORD=replace-me-unused
JIGASI_TRANSCRIBER_PASSWORD=replace-me-unused
JIBRI_RECORDER_PASSWORD=replace-me-unused
JIBRI_XMPP_PASSWORD=replace-me-unused

# Required for remote audio/video when using Docker — set to your machine's LAN IP (not 127.0.0.1).
# Find it: ipconfig getifaddr en0  (macOS)  or  hostname -I  (Linux)
# DOCKER_HOST_ADDRESS=192.168.1.10

JVB_PORT=10000
